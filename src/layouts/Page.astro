---
interface Props {
  title: string;
  description: string;
  canonical: string;
  mdPath: string;
}
const { title, description, canonical, mdPath } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content="llms.contentcucumber.com mirror" />
    <link rel="alternate" type="text/markdown" href={mdPath} title="Markdown source" />
    <style>
      :root { color-scheme: light dark; }
      body {
        font: 16px/1.65 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        max-width: 760px;
        margin: 2rem auto;
        padding: 0 1.2rem;
        color: #1a1a2e;
        background: #fff;
      }
      h1, h2, h3, h4 { line-height: 1.25; margin: 1.6em 0 0.5em; }
      h1 { font-size: 1.9rem; }
      h2 { font-size: 1.4rem; }
      h3 { font-size: 1.15rem; }
      h4 { font-size: 1rem; color: #444; }
      blockquote {
        margin: 1em 0; padding: 0.4em 1em;
        border-left: 3px solid #4caf50; color: #555; font-style: italic;
      }
      table { border-collapse: collapse; width: 100%; margin: 1em 0; }
      th, td { border: 1px solid #ddd; padding: 0.5em 0.7em; text-align: left; }
      a { color: #2e7d32; }
      hr { border: none; border-top: 1px solid #eee; margin: 2em 0; }
      footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #eee; font-size: 0.85rem; color: #777; }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <footer>
      Clean AI-readable mirror of
      <a href={canonical}>contentcucumber.com</a>.
      <a href={mdPath}>View Markdown source</a> ·
      <a href="/llms.txt">/llms.txt</a>
    </footer>
  </body>
</html>
